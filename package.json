{
  "name": "agentpay-firewall",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx server/index.ts",
    "dev:web": "vite --host 127.0.0.1 --port 5176",
    "build": "tsc && vite build",
    "test": "vitest run",
    "smoke": "tsx scripts/smoke.ts",
    "x402:ready": "tsx scripts/x402-official-readiness.ts",
    "x402:challenge": "tsx scripts/x402-official-challenge.ts",
    "x402:pay": "tsx scripts/x402-official-pay.ts",
    "dev:x402": "tsx server/x402-official.ts"
  },
  "dependencies": {
    "@x402/core": "2.18.0",
    "@x402/evm": "2.18.0",
    "@x402/express": "2.18.0",
    "@x402/fetch": "2.18.0",
    "express": "^5.2.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "viem": "2.47.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.13.14",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vercel/node": "^5.8.24",
    "tsx": "^4.20.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.19",
    "vitest": "^2.1.9"
  },
  "overrides": {
    "viem": "2.47.1"
  }
}
